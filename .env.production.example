# WatchMyAI backend production environment template.
# Copy the values into your VPS/hosting secret manager. Do not commit real secrets.

SPRING_PROFILES_ACTIVE=prod

# Database
DATABASE_URL=jdbc:postgresql://<host>:5432/watchmyai
DATABASE_USERNAME=<database-user>
DATABASE_PASSWORD=<database-password>
REDIS_URL=redis://<redis-host>:6379

# OpenAI
OPENAI_API_KEY=<openai-api-key>
WATCHMYAI_OPENAI_MOCK_ENABLED=false

# Sign in with Apple
APPLE_CLIENT_ID=com.sasanrafatnami.WatchMyAI
APPLE_TEAM_ID=<apple-team-id>
APPLE_SIGNIN_KEY_ID=<sign-in-with-apple-key-id>
APPLE_SIGNIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<contents-of-sign-in-with-apple-p8-key>\n-----END PRIVATE KEY-----"
WATCHMYAI_SESSION_TTL_DAYS=30
WATCHMYAI_LEGAL_CONTACT_EMAIL=support@watchmyai.app

# App Store Server API / StoreKit verification
APP_STORE_BUNDLE_ID=com.sasanrafatnami.WatchMyAI
APP_STORE_APP_APPLE_ID=<numeric-app-apple-id>
APP_STORE_ISSUER_ID=<app-store-connect-issuer-id>
APP_STORE_KEY_ID=<in-app-purchase-key-id>
APP_STORE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<contents-of-downloaded-p8-key>\n-----END PRIVATE KEY-----"

# Use SANDBOX for TestFlight. Switch to PRODUCTION for App Store release.
APP_STORE_ENVIRONMENT=SANDBOX
APP_STORE_VERIFICATION_ENABLED=true
